{
  "name": "@cab/driver-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev -p 3001",
    "build": "npm run build --prefix ../../shared && next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cab/shared": "file:../../shared",
    "firebase": "^11.0.2",
    "leaflet": "^1.9.4",
