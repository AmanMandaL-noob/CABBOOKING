NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<user>:<url-encoded-password>@<cluster>/<database>?retryWrites=true&w=majority&authSource=admin
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
CORS_ORIGINS=http://localhost:4000,http://localhost:3001,http://192.168.1.9:4000,http://192.168.1.9:3001
OTP_EXPIRY_MINUTES=10
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@cabdemo.local
